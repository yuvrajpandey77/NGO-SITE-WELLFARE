# Razorpay Payment Gateway Configuration
# Get your API keys from https://dashboard.razorpay.com/

# Server-side Razorpay credentials (keep these SECRET, never expose to client)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Client-side Razorpay key (can be exposed, same as RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Steps to configure:
# 1. Log in to Razorpay Dashboard: https://dashboard.razorpay.com/
# 2. Go to Settings → API Keys
# 3. Generate "Test Key" for development, "Live Key" for production
# 4. Copy the Key ID and Key Secret here
#
# Important:
# - Use Test mode (rzp_test_...) for development
# - Switch to Live mode (rzp_live_...) only for production
# - Never commit .env.local to version control
